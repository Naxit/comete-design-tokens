{
  "duration": {
    "instant": {
      "$type": "number",
      "$value": 0,
      "$description": "No animation"
    },
    "fast": {
      "$type": "number",
      "$value": 100,
      "$description": "Micro-interactions (hover, focus)"
    },
    "normal": {
      "$type": "number",
      "$value": 200,
      "$description": "Standard transitions"
    },
    "slow": {
      "$type": "number",
      "$value": 300,
      "$description": "Larger transitions (modals, panels)"
    },
    "slower": {
      "$type": "number",
      "$value": 500,
      "$description": "Complex animations"
    }
  },
  "easing": {
    "default": {
      "$type": "other",
      "$value": "cubic-bezier(0.2, 0, 0.38, 0.9)",
      "$description": "Standard easing for most transitions"
    },
    "entrance": {
      "$type": "other",
      "$value": "cubic-bezier(0, 0, 0.38, 0.9)",
      "$description": "Elements entering the screen"
    },
    "exit": {
      "$type": "other",
      "$value": "cubic-bezier(0.2, 0, 1, 0.9)",
      "$description": "Elements leaving the screen"
    },
    "linear": {
      "$type": "other",
      "$value": "linear",
      "$description": "Constant speed (spinners, progress)"
    }
  }
}
