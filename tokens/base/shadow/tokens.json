{
  "shadow": {
    "none": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "0",
        "blur": "0",
        "spread": "0",
        "color": "#00000000"
      }
    },
    "xs": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "1",
        "blur": "2",
        "spread": "0",
        "color": "#091e4224"
      }
    },
    "sm": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "1",
        "blur": "3",
        "spread": "1",
        "color": "#091e4224"
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "4",
        "blur": "8",
        "spread": "-1",
        "color": "#091e4224"
      }
    },
    "lg": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "8",
        "blur": "16",
        "spread": "-2",
        "color": "#091e4224"
      }
    },
    "xl": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "16",
        "blur": "24",
        "spread": "-4",
        "color": "#091e424f"
      }
    }
  }
}
